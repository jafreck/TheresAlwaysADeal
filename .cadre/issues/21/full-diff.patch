+import { describe, it, expect, vi, beforeEach, afterEach } from "vitest";
+import type { PriceAlertData } from "../../src/lib/slack.js";
+
+const sampleAlert: PriceAlertData = {
+  gameTitle: "Test Game",
+  gameImageUrl: "https://example.com/image.png",
+  currentPrice: "$19.99",
+  originalPrice: "$59.99",
+  discountPercent: 67,
+  buyUrl: "https://example.com/buy",
+  allPricesUrl: "https://example.com/prices",
+};
+
+describe("sendPriceAlert", () => {
+  let originalFetch: typeof globalThis.fetch;
+
+  beforeEach(() => {
+    originalFetch = globalThis.fetch;
+    vi.clearAllMocks();
+  });
+
+  afterEach(() => {
+    globalThis.fetch = originalFetch;
+  });
+
+  it("should return ok:true when webhook responds with 200", async () => {
+    globalThis.fetch = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    const result = await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    expect(result).toEqual({ ok: true });
+  });
+
+  it("should POST JSON to the provided webhook URL", async () => {
+    const mockFetch = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    globalThis.fetch = mockFetch;
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    expect(mockFetch).toHaveBeenCalledWith(
+      "https://hooks.slack.com/services/T1/B1/x",
+      expect.objectContaining({
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+      }),
+    );
+  });
+
+  it("should include blocks in the JSON payload", async () => {
+    const mockFetch = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    globalThis.fetch = mockFetch;
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    const body = JSON.parse(mockFetch.mock.calls[0][1].body);
+    expect(body.blocks).toBeDefined();
+    expect(body.blocks).toHaveLength(3);
+  });
+
+  it("should include game title in the payload", async () => {
+    const mockFetch = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    globalThis.fetch = mockFetch;
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    const body = JSON.parse(mockFetch.mock.calls[0][1].body);
+    expect(body.blocks[0].text.text).toContain("Test Game");
+  });
+
+  it("should return invalid_webhook for 4xx responses", async () => {
+    globalThis.fetch = vi.fn().mockResolvedValue({ ok: false, status: 403 });
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    const result = await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    expect(result).toEqual({ ok: false, reason: "invalid_webhook" });
+  });
+
+  it("should return invalid_webhook for 400 response", async () => {
+    globalThis.fetch = vi.fn().mockResolvedValue({ ok: false, status: 400 });
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    const result = await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    expect(result).toEqual({ ok: false, reason: "invalid_webhook" });
+  });
+
+  it("should return transient_error for 5xx responses", async () => {
+    globalThis.fetch = vi.fn().mockResolvedValue({ ok: false, status: 500 });
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    const result = await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    expect(result).toEqual({ ok: false, reason: "transient_error" });
+  });
+
+  it("should return transient_error when fetch throws a network error", async () => {
+    globalThis.fetch = vi.fn().mockRejectedValue(new Error("Network error"));
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    const result = await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    expect(result).toEqual({ ok: false, reason: "transient_error" });
+  });
+
+  it("should include discount percent in the payload", async () => {
+    const mockFetch = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    globalThis.fetch = mockFetch;
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    const body = JSON.parse(mockFetch.mock.calls[0][1].body);
+    const fieldsBlock = body.blocks[1];
+    const discountField = fieldsBlock.fields.find((f: any) => f.text.includes("Discount"));
+    expect(discountField.text).toContain("67% off");
+  });
+
+  it("should include Buy Now and See All Prices buttons", async () => {
+    const mockFetch = vi.fn().mockResolvedValue({ ok: true, status: 200 });
+    globalThis.fetch = mockFetch;
+    const { sendPriceAlert } = await import("../../src/lib/slack.js");
+    await sendPriceAlert("https://hooks.slack.com/services/T1/B1/x", sampleAlert);
+    const body = JSON.parse(mockFetch.mock.calls[0][1].body);
+    const actions = body.blocks[2];
+    expect(actions.elements).toHaveLength(2);
+    expect(actions.elements[0].text.text).toBe("Buy Now");
+    expect(actions.elements[0].url).toBe(sampleAlert.buyUrl);
+    expect(actions.elements[1].text.text).toBe("See All Prices");
+    expect(actions.elements[1].url).toBe(sampleAlert.allPricesUrl);
+  });
+});
