+// ─── Graceful shutdown includes slack notification worker ─────────────────────
+describe("graceful shutdown", () => {
+  it("should have created a Worker for slack-notification that is included in shutdown", () => {
+    const calls = vi.mocked(Worker).mock.calls.map(([name]) => name);
+    expect(calls).toContain("slack-notification");
+    // All four workers are created and will be closed by the SIGTERM handler
+    expect(calls).toContain("scrape");
+    expect(calls).toContain("ingest");
+    expect(calls).toContain("featured-scrape");
+  });
+});
