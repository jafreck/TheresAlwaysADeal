+  encrypt: (...args: unknown[]) => mockEncrypt(...args),
+}));
+
+const mockSendPriceAlert = vi.fn();
+vi.mock("../../src/lib/slack.js", () => ({
+  sendPriceAlert: (...args: unknown[]) => mockSendPriceAlert(...args),
+}));
+
+// DB mock
+const mockDb = {
+  update: vi.fn().mockReturnValue({
+    set: vi.fn().mockReturnValue({
+      where: vi.fn().mockResolvedValue([]),
+    }),
+  }),
+};
+
+const stubTable = (cols: Record<string, string>) => cols;
+
+vi.mock("@taad/db", () => ({
+  db: mockDb,
+  users: stubTable({
+    id: "id",
+    email: "email",
+    notifySlackWebhook: "notifySlackWebhook",
+  }),
+}));
+
+vi.mock("drizzle-orm", () => ({
+  eq: vi.fn((col: string, val: unknown) => ({ col, val })),
+}));
+
+// Auth middleware mock — inject user payload
+const mockVerifyAccessToken = vi.fn();
+vi.mock("../../src/lib/jwt.js", () => ({
+  verifyAccessToken: (...args: unknown[]) => mockVerifyAccessToken(...args),
+}));
+
+// ─── App under test ───────────────────────────────────────────────────────────
+
+const { createUserAlertsApp } = await import("../../src/routes/user-alerts.js");
+
+const app = createUserAlertsApp(() => null);
+
+const VALID_WEBHOOK = "https://hooks.slack.com/services/T0123ABC/B0123DEF/abcdefghijklmnop";
+
+function makeRequest(body: unknown, token = "valid-token") {
+  return new Request("http://localhost/test-slack", {
+    method: "POST",
+    headers: {
+      "Content-Type": "application/json",
+      Authorization: `Bearer ${token}`,
+    },
+    body: JSON.stringify(body),
+  });
+}
+
+describe("POST /test-slack", () => {
+  beforeEach(() => {
+    vi.clearAllMocks();
+    mockVerifyAccessToken.mockReturnValue({ sub: "user-123", email: "test@example.com" });
+    mockSendPriceAlert.mockResolvedValue({ ok: true });
+    // Reset DB mock chain
+    mockDb.update.mockReturnValue({
+      set: vi.fn().mockReturnValue({
+        where: vi.fn().mockResolvedValue([]),
+      }),
+    });
+  });
+
+  it("should return 401 when no Authorization header is provided", async () => {
+    const req = new Request("http://localhost/test-slack", {
+      method: "POST",
+      headers: { "Content-Type": "application/json" },
+      body: JSON.stringify({ webhookUrl: VALID_WEBHOOK }),
+    });
+    const res = await app.request(req);
+    expect(res.status).toBe(401);
+  });
+
+  it("should return 401 when token is invalid", async () => {
+    mockVerifyAccessToken.mockImplementation(() => {
+      throw new Error("invalid token");
+    });
+    const res = await app.request(makeRequest({ webhookUrl: VALID_WEBHOOK }));
+    expect(res.status).toBe(401);
+  });
+
+  it("should return 400 for invalid webhook URL", async () => {
+    const res = await app.request(makeRequest({ webhookUrl: "https://example.com/bad" }));
+    expect(res.status).toBe(400);
+    const body = await res.json();
+    expect(body.error).toBe("Invalid input");
+  });
+
+  it("should return 400 when webhookUrl is missing", async () => {
+    const res = await app.request(makeRequest({}));
+    expect(res.status).toBe(400);
+  });
+
+  it("should return 400 when webhookUrl is empty", async () => {
+    const res = await app.request(makeRequest({ webhookUrl: "" }));
+    expect(res.status).toBe(400);
+  });
+
+  it("should encrypt and store the webhook URL", async () => {
+    const res = await app.request(makeRequest({ webhookUrl: VALID_WEBHOOK }));
+    expect(res.status).toBe(200);
+    expect(mockEncrypt).toHaveBeenCalledWith(VALID_WEBHOOK);
+    expect(mockDb.update).toHaveBeenCalled();
+  });
+
+  it("should send a sample Slack message with test data", async () => {
+    const res = await app.request(makeRequest({ webhookUrl: VALID_WEBHOOK }));
+    expect(res.status).toBe(200);
+    expect(mockSendPriceAlert).toHaveBeenCalledWith(
+      VALID_WEBHOOK,
+      expect.objectContaining({
+        gameTitle: expect.any(String),
+        currentPrice: expect.any(String),
+        originalPrice: expect.any(String),
+        discountPercent: expect.any(Number),
+        buyUrl: expect.any(String),
+        allPricesUrl: expect.any(String),
+      }),
+    );
+  });
+
+  it("should return 200 with success message on successful send", async () => {
+    const res = await app.request(makeRequest({ webhookUrl: VALID_WEBHOOK }));
+    expect(res.status).toBe(200);
+    const body = await res.json();
+    expect(body.message).toBe("Test Slack message sent successfully");
+  });
+
+  it("should return 400 when Slack reports invalid_webhook", async () => {
+    mockSendPriceAlert.mockResolvedValue({ ok: false, reason: "invalid_webhook" });
+    const res = await app.request(makeRequest({ webhookUrl: VALID_WEBHOOK }));
+    expect(res.status).toBe(400);
+    const body = await res.json();
+    expect(body.error).toBe("Invalid Slack webhook URL");
+  });
+
+  it("should return 502 when Slack reports transient_error", async () => {
+    mockSendPriceAlert.mockResolvedValue({ ok: false, reason: "transient_error" });
+    const res = await app.request(makeRequest({ webhookUrl: VALID_WEBHOOK }));
+    expect(res.status).toBe(502);
+    const body = await res.json();
+    expect(body.error).toContain("Failed to send");
+  });
+});
