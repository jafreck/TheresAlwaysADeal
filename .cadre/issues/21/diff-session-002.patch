+// ─── AES-256-GCM Decryption (mirrors packages/api/src/lib/encryption.ts) ─────
+function decryptWebhookUrl(ciphertext: string): string {
+  const hex = process.env.SLACK_ENCRYPTION_KEY;
+  if (!hex) throw new Error("SLACK_ENCRYPTION_KEY is not set");
+  const key = Buffer.from(hex, "hex");
+  const data = Buffer.from(ciphertext, "hex");
+  const iv = data.subarray(0, 12);
+  const authTag = data.subarray(12, 28);
+  const encrypted = data.subarray(28);
+  const decipher = createDecipheriv("aes-256-gcm", key, iv);
+  decipher.setAuthTag(authTag);
+  return decipher.update(encrypted) + decipher.final("utf8");
+}
+
+// ─── Slack Notification Helpers ───────────────────────────────────────────────
+async function enqueueSlackNotifications(
+  gameId: string,
+  storeListingId: string,
+  newPrice: number,
+  previousPrice: number | undefined,
+  eventType: "price-drop" | "all-time-low",
+) {
+  const activeAlerts = await db
+    .select({
+      alertId: priceAlerts.id,
