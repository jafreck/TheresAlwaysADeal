@@ -0,0 +1,61 @@
+import { Hono } from "hono";
+import { eq } from "drizzle-orm";
+import type { Redis as RedisClient } from "ioredis";
+import { db, users } from "@taad/db";
+import { authMiddleware } from "../middleware/auth.js";
+import { testSlackSchema } from "../lib/validation.js";
+import { encrypt } from "../lib/encryption.js";
+import { sendPriceAlert } from "../lib/slack.js";
+
+type Env = { Variables: { user: Record<string, unknown> } };
+
+export function createUserAlertsApp(_getRedis: () => RedisClient | null) {
+  const app = new Hono<Env>();
+
+  app.use("*", authMiddleware);
+
+  // POST /test-slack
+  app.post("/test-slack", async (c) => {
+    const body = await c.req.json();
+    const parsed = testSlackSchema.safeParse(body);
+    if (!parsed.success) {
+      return c.json(
+        { error: "Invalid input", details: parsed.error.flatten() },
+        400,
+      );
+    }
+
+    const { webhookUrl } = parsed.data;
+    const user = c.get("user") as Record<string, unknown>;
+    const userId = user.sub as string;
+
+    // Encrypt and store webhook URL on user record
+    const encryptedWebhook = encrypt(webhookUrl);
+    await db
+      .update(users)
+      .set({ notifySlackWebhook: encryptedWebhook })
+      .where(eq(users.id, userId));
+
+    // Send a sample Slack message
+    const result = await sendPriceAlert(webhookUrl, {
+      gameTitle: "Test Game — Price Alert Setup",
+      gameImageUrl: "https://placehold.co/300x150?text=Game+Image",
+      currentPrice: "$19.99",
+      originalPrice: "$59.99",
+      discountPercent: 67,
+      buyUrl: "https://example.com/buy",
+      allPricesUrl: "https://example.com/prices",
+    });
+
+    if (!result.ok) {
+      if (result.reason === "invalid_webhook") {
+        return c.json({ error: "Invalid Slack webhook URL" }, 400);
+      }
+      return c.json({ error: "Failed to send test message, please try again" }, 502);
+    }
+
+    return c.json({ message: "Test Slack message sent successfully" }, 200);
+  });
+
+  return app;
+}
