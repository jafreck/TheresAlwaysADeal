diff --git a/packages/api/src/routes/user.ts b/packages/api/src/routes/user.ts
new file mode 100644
index 0000000..9208c21
--- /dev/null
+++ b/packages/api/src/routes/user.ts
@@ -0,0 +1,197 @@
+import { Hono } from "hono";
+import { eq } from "drizzle-orm";
+import { db, users } from "@taad/db";
+import { hashPassword, verifyPassword } from "../lib/password.js";
+import {
+  updateProfileSchema,
+  changePasswordSchema,
+} from "../lib/validation.js";
+import { authMiddleware } from "../middleware/auth.js";
+
+type Variables = {
+  user: { sub: string; email: string };
+};
+
+export function createUserApp() {
+  const app = new Hono<{ Variables: Variables }>();
+
+  // All user routes require authentication
+  app.use("*", authMiddleware);
+
+  // GET /me - Get current user profile
+  app.get("/me", async (c) => {
+    const { sub: userId } = c.get("user");
+
+    const [user] = await db
+      .select({
+        id: users.id,
+        email: users.email,
+        displayName: users.displayName,
+        name: users.name,
+        emailVerified: users.emailVerified,
+        steamId: users.steamId,
+        emailAlerts: users.emailAlerts,
+        slackAlertsEnabled: users.slackAlertsEnabled,
+        slackWebhookUrl: users.slackWebhookUrl,
+        defaultAlertCurrency: users.defaultAlertCurrency,
+        createdAt: users.createdAt,
+      })
+      .from(users)
+      .where(eq(users.id, userId))
+      .limit(1);
+
+    if (!user) {
+      return c.json({ error: "User not found" }, 404);
+    }
+
+    return c.json({
+      id: user.id,
+      email: user.email,
+      displayName: user.displayName ?? user.name,
+      emailVerified: user.emailVerified,
+      steamId: user.steamId,
+      steamLinked: user.steamId != null,
+      notificationPreferences: {
+        emailAlerts: user.emailAlerts,
+        slackAlertsEnabled: user.slackAlertsEnabled,
+        slackWebhookUrl: user.slackWebhookUrl,
+        defaultAlertCurrency: user.defaultAlertCurrency,
+      },
+      createdAt: user.createdAt,
+    }, 200);
+  });
+
+  // PATCH /me - Update profile
+  app.patch("/me", async (c) => {
+    const { sub: userId } = c.get("user");
+
+    const body = await c.req.json();
+    const parsed = updateProfileSchema.safeParse(body);
+    if (!parsed.success) {
+      return c.json(
+        { error: "Invalid input", details: parsed.error.flatten() },
+        400,
+      );
+    }
+
+    const updates: Record<string, unknown> = {};
+    if (parsed.data.displayName !== undefined) updates.displayName = parsed.data.displayName;
+    if (parsed.data.emailAlerts !== undefined) updates.emailAlerts = parsed.data.emailAlerts;
+    if (parsed.data.slackAlertsEnabled !== undefined) updates.slackAlertsEnabled = parsed.data.slackAlertsEnabled;
+    if (parsed.data.slackWebhookUrl !== undefined) updates.slackWebhookUrl = parsed.data.slackWebhookUrl;
+    if (parsed.data.defaultAlertCurrency !== undefined) updates.defaultAlertCurrency = parsed.data.defaultAlertCurrency;
+
+    if (Object.keys(updates).length > 0) {
+      await db.update(users).set(updates).where(eq(users.id, userId));
+    }
+
+    const [updated] = await db
+      .select({
+        id: users.id,
+        email: users.email,
+        displayName: users.displayName,
+        name: users.name,
+        emailVerified: users.emailVerified,
+        steamId: users.steamId,
+        emailAlerts: users.emailAlerts,
+        slackAlertsEnabled: users.slackAlertsEnabled,
+        slackWebhookUrl: users.slackWebhookUrl,
+        defaultAlertCurrency: users.defaultAlertCurrency,
+        createdAt: users.createdAt,
+      })
+      .from(users)
+      .where(eq(users.id, userId))
+      .limit(1);
+
+    if (!updated) {
+      return c.json({ error: "User not found" }, 404);
+    }
+
+    return c.json({
+      id: updated.id,
+      email: updated.email,
+      displayName: updated.displayName ?? updated.name,
+      emailVerified: updated.emailVerified,
+      steamId: updated.steamId,
+      steamLinked: updated.steamId != null,
+      notificationPreferences: {
+        emailAlerts: updated.emailAlerts,
+        slackAlertsEnabled: updated.slackAlertsEnabled,
+        slackWebhookUrl: updated.slackWebhookUrl,
+        defaultAlertCurrency: updated.defaultAlertCurrency,
+      },
+      createdAt: updated.createdAt,
+    }, 200);
+  });
+
+  // POST /me/change-password - Change password
+  app.post("/me/change-password", async (c) => {
+    const { sub: userId } = c.get("user");
+
+    const body = await c.req.json();
+    const parsed = changePasswordSchema.safeParse(body);
+    if (!parsed.success) {
+      return c.json(
+        { error: "Invalid input", details: parsed.error.flatten() },
+        400,
+      );
+    }
+
+    const [user] = await db
+      .select({ id: users.id, passwordHash: users.passwordHash })
+      .from(users)
+      .where(eq(users.id, userId))
+      .limit(1);
+
+    if (!user || !user.passwordHash) {
+      return c.json({ error: "User not found" }, 404);
+    }
+
+    const valid = await verifyPassword(parsed.data.currentPassword, user.passwordHash);
+    if (!valid) {
+      return c.json({ error: "Current password is incorrect" }, 400);
+    }
+
+    const newHash = await hashPassword(parsed.data.newPassword);
+    await db.update(users).set({ passwordHash: newHash }).where(eq(users.id, userId));
+
+    return c.json({ message: "Password changed successfully" }, 200);
+  });
+
+  // DELETE /me - Delete account (GDPR anonymization)
+  app.delete("/me", async (c) => {
+    const { sub: userId } = c.get("user");
+
+    const [user] = await db
+      .select({ id: users.id, email: users.email })
+      .from(users)
+      .where(eq(users.id, userId))
+      .limit(1);
+
+    if (!user) {
+      return c.json({ error: "User not found" }, 404);
+    }
+
+    const hashedEmail = await hashPassword(user.email);
+
+    await db
+      .update(users)
+      .set({
+        email: hashedEmail,
+        name: "deleted",
+        displayName: "deleted",
+        passwordHash: null,
+        steamId: null,
+        steamAccessToken: null,
+        emailVerificationToken: null,
+        passwordResetToken: null,
+        passwordResetExpires: null,
+        emailVerified: false,
+      })
+      .where(eq(users.id, userId));
+
+    return c.json({ message: "Account deleted successfully" }, 200);
+  });
+
+  return app;
+}
