@@ -0,0 +1,394 @@
+import { describe, it, expect, vi, beforeEach } from "vitest";
+
+// ─── Mocks (hoisted before imports) ──────────────────────────────────────────
+
+const mockHashPassword = vi.fn();
+const mockVerifyPassword = vi.fn();
+vi.mock("../../src/lib/password.js", () => ({
+  hashPassword: (...args: unknown[]) => mockHashPassword(...args),
+  verifyPassword: (...args: unknown[]) => mockVerifyPassword(...args),
+}));
+
+const mockVerifyAccessToken = vi.fn();
+vi.mock("../../src/lib/jwt.js", () => ({
+  verifyAccessToken: (...args: unknown[]) => mockVerifyAccessToken(...args),
+}));
+
+// DB mock
+let mockDbSelectResult: any[] = [];
+let mockDbUpdateResult: any[] = [];
+
+function createSelectBuilder() {
+  const builder: any = {
+    from: () => builder,
+    where: () => builder,
+    limit: () => Promise.resolve(mockDbSelectResult),
+    then: (resolve: (v: any) => any, reject: (e: any) => any) =>
+      Promise.resolve(mockDbSelectResult).then(resolve, reject),
+  };
+  return builder;
+}
+
+const mockUpdateSet = vi.fn();
+const mockUpdateWhere = vi.fn();
+
+const mockDb = {
+  select: vi.fn().mockReturnValue(createSelectBuilder()),
+  update: vi.fn().mockReturnValue({
+    set: vi.fn().mockImplementation((...args: unknown[]) => {
+      mockUpdateSet(...args);
+      return {
+        where: vi.fn().mockImplementation((...wArgs: unknown[]) => {
+          mockUpdateWhere(...wArgs);
+          return Promise.resolve(mockDbUpdateResult);
+        }),
+      };
+    }),
+  }),
+};
+
+const stubTable = (cols: Record<string, string>) => cols;
+
+vi.mock("@taad/db", () => ({
+  db: mockDb,
+  users: stubTable({
+    id: "id",
+    email: "email",
+    name: "name",
+    displayName: "displayName",
+    passwordHash: "passwordHash",
+    emailVerified: "emailVerified",
+    emailVerificationToken: "emailVerificationToken",
+    passwordResetToken: "passwordResetToken",
+    passwordResetExpires: "passwordResetExpires",
+    steamId: "steamId",
+    steamAccessToken: "steamAccessToken",
+    emailAlerts: "emailAlerts",
+    slackAlertsEnabled: "slackAlertsEnabled",
+    slackWebhookUrl: "slackWebhookUrl",
+    defaultAlertCurrency: "defaultAlertCurrency",
+    createdAt: "createdAt",
+  }),
+}));
+
+vi.mock("drizzle-orm", () => ({
+  eq: vi.fn((col: string, val: unknown) => ({ col, val })),
+}));
+
+// ─── App under test ───────────────────────────────────────────────────────────
+
+const { createUserApp } = await import("../../src/routes/user.js");
+
+// ─── Helpers ──────────────────────────────────────────────────────────────────
+
+const TEST_USER = {
+  id: "user-1",
+  email: "test@example.com",
+  displayName: "Test User",
+  name: "Test Name",
+  emailVerified: true,
+  steamId: "steam-123",
+  emailAlerts: true,
+  slackAlertsEnabled: false,
+  slackWebhookUrl: null,
+  defaultAlertCurrency: "USD",
+  createdAt: new Date("2024-01-01"),
+};
+
+function makeApp() {
+  return createUserApp();
+}
+
+function authedRequest(app: any, path: string, opts: RequestInit = {}) {
+  mockVerifyAccessToken.mockReturnValue({ sub: "user-1", email: "test@example.com" });
+  return app.request(path, {
+    headers: {
+      Authorization: "Bearer valid-token",
+      "Content-Type": "application/json",
+      ...(opts.headers || {}),
+    },
+    ...opts,
+  });
+}
+
+function jsonBody(body: any): RequestInit {
+  return {
+    method: "PATCH",
+    body: JSON.stringify(body),
+  };
+}
+
+// ─── Tests ────────────────────────────────────────────────────────────────────
+
+describe("GET /me", () => {
+  beforeEach(() => {
+    vi.clearAllMocks();
+    mockDbSelectResult = [{ ...TEST_USER }];
+    mockDb.select.mockReturnValue(createSelectBuilder());
+  });
+
+  it("returns 200 with complete profile including computed steamLinked", async () => {
+    const app = makeApp();
+    const res = await authedRequest(app, "/me");
+    expect(res.status).toBe(200);
+
+    const json = await res.json();
+    expect(json.id).toBe("user-1");
+    expect(json.email).toBe("test@example.com");
+    expect(json.displayName).toBe("Test User");
+    expect(json.emailVerified).toBe(true);
+    expect(json.steamId).toBe("steam-123");
+    expect(json.steamLinked).toBe(true);
+    expect(json.notificationPreferences).toEqual({
+      emailAlerts: true,
+      slackAlertsEnabled: false,
+      slackWebhookUrl: null,
+      defaultAlertCurrency: "USD",
+    });
+    expect(json.createdAt).toBeDefined();
+  });
+
+  it("returns steamLinked false when steamId is null", async () => {
+    mockDbSelectResult = [{ ...TEST_USER, steamId: null }];
+    mockDb.select.mockReturnValue(createSelectBuilder());
+
+    const app = makeApp();
+    const res = await authedRequest(app, "/me");
+    const json = await res.json();
+    expect(json.steamLinked).toBe(false);
+  });
+
+  it("falls back to name when displayName is null", async () => {
+    mockDbSelectResult = [{ ...TEST_USER, displayName: null }];
+    mockDb.select.mockReturnValue(createSelectBuilder());
+
+    const app = makeApp();
+    const res = await authedRequest(app, "/me");
+    const json = await res.json();
+    expect(json.displayName).toBe("Test Name");
+  });
+
+  it("returns 401 when no auth header provided", async () => {
+    const app = makeApp();
+    const res = await app.request("/me");
+    expect(res.status).toBe(401);
