+} from "../../src/lib/validation.js";
+
+const VALID_UUID = "a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11";
+const VALID_UUID_2 = "b1ffcd00-ad1c-5fa9-cc7e-7ccace491b22";
+
+describe("createAlertSchema", () => {
+  it("should accept valid input with targetPrice", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetPrice: 19.99,
+    });
+    expect(result.gameId).toBe(VALID_UUID);
+    expect(result.targetPrice).toBe(19.99);
+  });
+
+  it("should accept valid input with targetDiscountPercent", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetDiscountPercent: 50,
+    });
+    expect(result.targetDiscountPercent).toBe(50);
+  });
+
+  it("should accept both targetPrice and targetDiscountPercent", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetPrice: 9.99,
+      targetDiscountPercent: 75,
+    });
+    expect(result.targetPrice).toBe(9.99);
+    expect(result.targetDiscountPercent).toBe(75);
+  });
+
+  it("should reject when neither targetPrice nor targetDiscountPercent provided", () => {
+    expect(() =>
+      createAlertSchema.parse({ gameId: VALID_UUID }),
+    ).toThrow();
+  });
+
+  it("should require gameId", () => {
+    expect(() =>
+      createAlertSchema.parse({ targetPrice: 9.99 }),
+    ).toThrow();
+  });
+
+  it("should reject non-UUID gameId", () => {
+    expect(() =>
+      createAlertSchema.parse({ gameId: "not-a-uuid", targetPrice: 9.99 }),
+    ).toThrow();
+  });
+
+  it("should accept optional storeId as UUID", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      storeId: VALID_UUID_2,
+      targetPrice: 9.99,
+    });
+    expect(result.storeId).toBe(VALID_UUID_2);
+  });
+
+  it("should reject non-UUID storeId", () => {
+    expect(() =>
+      createAlertSchema.parse({
+        gameId: VALID_UUID,
+        storeId: "bad",
+        targetPrice: 9.99,
+      }),
+    ).toThrow();
+  });
+
+  it("should reject non-positive targetPrice", () => {
+    expect(() =>
+      createAlertSchema.parse({ gameId: VALID_UUID, targetPrice: 0 }),
+    ).toThrow();
+    expect(() =>
+      createAlertSchema.parse({ gameId: VALID_UUID, targetPrice: -5 }),
+    ).toThrow();
+  });
+
+  it("should reject targetDiscountPercent above 100", () => {
+    expect(() =>
+      createAlertSchema.parse({ gameId: VALID_UUID, targetDiscountPercent: 101 }),
+    ).toThrow();
+  });
+
+  it("should reject negative targetDiscountPercent", () => {
+    expect(() =>
+      createAlertSchema.parse({ gameId: VALID_UUID, targetDiscountPercent: -1 }),
+    ).toThrow();
+  });
+
+  it("should accept targetDiscountPercent of 0", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetDiscountPercent: 0,
+      targetPrice: 5,
+    });
+    expect(result.targetDiscountPercent).toBe(0);
+  });
+
+  it("should accept targetDiscountPercent of 100", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetDiscountPercent: 100,
+    });
+    expect(result.targetDiscountPercent).toBe(100);
+  });
+
+  it("should accept optional notifyEmail boolean", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetPrice: 9.99,
+      notifyEmail: false,
+    });
+    expect(result.notifyEmail).toBe(false);
+  });
+
+  it("should accept optional notifySlackWebhook as URL", () => {
+    const result = createAlertSchema.parse({
+      gameId: VALID_UUID,
+      targetPrice: 9.99,
+      notifySlackWebhook: "https://hooks.slack.com/services/T00/B00/xxx",
+    });
+    expect(result.notifySlackWebhook).toBe(
+      "https://hooks.slack.com/services/T00/B00/xxx",
+    );
+  });
+
+  it("should reject invalid notifySlackWebhook URL", () => {
+    expect(() =>
+      createAlertSchema.parse({
+        gameId: VALID_UUID,
+        targetPrice: 9.99,
+        notifySlackWebhook: "not-a-url",
+      }),
+    ).toThrow();
+  });
+});
+
+describe("updateAlertSchema", () => {
+  it("should accept empty object (all fields optional)", () => {
+    const result = updateAlertSchema.parse({});
+    expect(result).toEqual({});
+  });
+
+  it("should accept targetPrice update", () => {
+    const result = updateAlertSchema.parse({ targetPrice: 14.99 });
+    expect(result.targetPrice).toBe(14.99);
+  });
+
+  it("should accept targetDiscountPercent update", () => {
+    const result = updateAlertSchema.parse({ targetDiscountPercent: 25 });
+    expect(result.targetDiscountPercent).toBe(25);
+  });
+
+  it("should accept storeId update", () => {
+    const result = updateAlertSchema.parse({ storeId: VALID_UUID });
+    expect(result.storeId).toBe(VALID_UUID);
+  });
+
+  it("should accept notifyEmail update", () => {
+    const result = updateAlertSchema.parse({ notifyEmail: true });
+    expect(result.notifyEmail).toBe(true);
+  });
+
+  it("should accept notifySlackWebhook update", () => {
+    const result = updateAlertSchema.parse({
+      notifySlackWebhook: "https://hooks.slack.com/services/T00/B00/xxx",
+    });
+    expect(result.notifySlackWebhook).toBe(
+      "https://hooks.slack.com/services/T00/B00/xxx",
+    );
+  });
+
+  it("should not accept gameId (not updatable)", () => {
+    const result = updateAlertSchema.parse({ gameId: VALID_UUID } as any);
+    expect((result as any).gameId).toBeUndefined();
+  });
+
+  it("should reject non-positive targetPrice", () => {
+    expect(() => updateAlertSchema.parse({ targetPrice: 0 })).toThrow();
+  });
+
+  it("should reject targetDiscountPercent above 100", () => {
+    expect(() =>
+      updateAlertSchema.parse({ targetDiscountPercent: 101 }),
+    ).toThrow();
+  });
+
+  it("should reject invalid notifySlackWebhook URL", () => {
+    expect(() =>
+      updateAlertSchema.parse({ notifySlackWebhook: "bad" }),
+    ).toThrow();
+  });
+
+  it("should reject non-UUID storeId", () => {
+    expect(() => updateAlertSchema.parse({ storeId: "bad" })).toThrow();
+  });
+});
