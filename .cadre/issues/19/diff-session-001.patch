diff --git a/packages/api/tests/lib/encryption.test.ts b/packages/api/tests/lib/encryption.test.ts
new file mode 100644
index 0000000..466a4a3
--- /dev/null
+++ b/packages/api/tests/lib/encryption.test.ts
@@ -0,0 +1,112 @@
+import { describe, it, expect, vi, beforeEach, afterEach } from "vitest";
+import { randomBytes } from "node:crypto";
+
+// 32-byte key as 64-char hex string
+const TEST_KEY = randomBytes(32).toString("hex");
+
+describe("encryption", () => {
+  const originalEnv = process.env.ENCRYPTION_KEY;
+
+  beforeEach(() => {
+    vi.resetModules();
+    process.env.ENCRYPTION_KEY = TEST_KEY;
+  });
+
+  afterEach(() => {
+    if (originalEnv !== undefined) {
+      process.env.ENCRYPTION_KEY = originalEnv;
+    } else {
+      delete process.env.ENCRYPTION_KEY;
+    }
+  });
+
+  async function loadModule() {
+    return import("../../src/lib/encryption.js");
+  }
+
+  describe("encrypt", () => {
+    it("should return a string in iv:authTag:ciphertext format", async () => {
+      const { encrypt } = await loadModule();
+      const result = encrypt("hello world");
+      const parts = result.split(":");
+      expect(parts).toHaveLength(3);
+      // IV = 12 bytes = 24 hex chars
+      expect(parts[0]).toHaveLength(24);
+      // AuthTag = 16 bytes = 32 hex chars
+      expect(parts[1]).toHaveLength(32);
+      // Ciphertext should be non-empty hex
+      expect(parts[2].length).toBeGreaterThan(0);
+      expect(parts[2]).toMatch(/^[0-9a-f]+$/);
+    });
+
+    it("should produce different ciphertexts for the same plaintext (random IV)", async () => {
+      const { encrypt } = await loadModule();
+      const a = encrypt("same input");
+      const b = encrypt("same input");
+      expect(a).not.toBe(b);
+    });
+
+    it("should handle empty string plaintext", async () => {
+      const { encrypt } = await loadModule();
+      const result = encrypt("");
+      const parts = result.split(":");
+      expect(parts).toHaveLength(3);
+    });
+
+    it("should handle unicode plaintext", async () => {
+      const { encrypt, decrypt } = await loadModule();
+      const plaintext = "日本語テスト 🎮";
+      const encrypted = encrypt(plaintext);
+      expect(decrypt(encrypted)).toBe(plaintext);
+    });
+
+    it("should throw when ENCRYPTION_KEY is not set", async () => {
+      delete process.env.ENCRYPTION_KEY;
+      const { encrypt } = await loadModule();
+      expect(() => encrypt("test")).toThrow("ENCRYPTION_KEY environment variable is not set");
+    });
+  });
+
+  describe("decrypt", () => {
+    it("should decrypt back to the original plaintext", async () => {
+      const { encrypt, decrypt } = await loadModule();
+      const plaintext = "secret webhook url";
+      const encrypted = encrypt(plaintext);
+      expect(decrypt(encrypted)).toBe(plaintext);
+    });
+
+    it("should decrypt empty string plaintext", async () => {
+      const { encrypt, decrypt } = await loadModule();
+      const encrypted = encrypt("");
+      expect(decrypt(encrypted)).toBe("");
+    });
+
+    it("should throw on tampered ciphertext", async () => {
+      const { encrypt, decrypt } = await loadModule();
+      const encrypted = encrypt("test");
+      const parts = encrypted.split(":");
+      // Flip a character in the ciphertext
+      const tampered = parts[2][0] === "a" ? "b" : "a";
+      const bad = `${parts[0]}:${parts[1]}:${tampered}${parts[2].slice(1)}`;
+      expect(() => decrypt(bad)).toThrow();
+    });
+
+    it("should throw on tampered auth tag", async () => {
+      const { encrypt, decrypt } = await loadModule();
+      const encrypted = encrypt("test");
+      const parts = encrypted.split(":");
+      const tampered = parts[1][0] === "a" ? "b" : "a";
+      const bad = `${parts[0]}:${tampered}${parts[1].slice(1)}:${parts[2]}`;
+      expect(() => decrypt(bad)).toThrow();
+    });
+
+    it("should throw when ENCRYPTION_KEY is not set", async () => {
+      const { encrypt, decrypt } = await loadModule();
+      const encrypted = encrypt("test");
+      delete process.env.ENCRYPTION_KEY;
+      // Re-import to get fresh module
+      const fresh = await loadModule();
+      expect(() => fresh.decrypt(encrypted)).toThrow("ENCRYPTION_KEY environment variable is not set");
+    });
+  });
+});
