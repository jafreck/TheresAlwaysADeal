+    values: vi.fn().mockReturnValue({
+      returning: vi.fn().mockImplementation(() => Promise.resolve(mockDbInsertResult)),
+    }),
+  }),
+  update: vi.fn().mockReturnValue({
+    set: vi.fn().mockReturnValue({
