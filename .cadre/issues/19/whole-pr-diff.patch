+  it("should handle no active alerts gracefully", async () => {
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValueOnce(buildSelectChain([mockListing]))
+      .mockReturnValueOnce(buildSelectChain([])); // no alerts
+
+    mockQueueAdd.mockClear();
+
+    const processor = getPriceDropAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", previousPrice: 19.99, newPrice: 9.99 } });
+
+    const notifCalls = mockQueueAdd.mock.calls.filter(([name]: [string]) => name === "alert-notification");
+    expect(notifCalls).toHaveLength(0);
+  });
+
+  it("should insert alertNotifications row with correct triggeredPrice", async () => {
+    const alert = {
+      id: "alert-5", userId: "user-1", gameId: "game-1", storeId: null,
+      targetPrice: "20.00", targetDiscountPercent: null,
+      notifyEmail: true, notifySlackWebhook: null,
+    };
+    const latestRecord = { discount: null };
+
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValueOnce(buildSelectChain([mockListing]))
+      .mockReturnValueOnce(buildSelectChain([alert]))
+      .mockReturnValueOnce(buildSelectChain([latestRecord]));
+
+    const insertValuesChain = { values: vi.fn().mockReturnThis(), returning: vi.fn().mockResolvedValue([{}]) };
+    (db.insert as ReturnType<typeof vi.fn>).mockReturnValue(insertValuesChain);
+
+    const processor = getPriceDropAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", previousPrice: 19.99, newPrice: 7.50 } });
+
+    const valuesArg = insertValuesChain.values.mock.calls.find(
+      ([v]: [{ triggeredPrice?: string }]) => v.triggeredPrice !== undefined,
+    );
+    expect(valuesArg).toBeDefined();
+    expect(valuesArg![0].triggeredPrice).toBe("7.5");
+  });
+});
+
+// ─── All-Time-Low Alert Worker tests ──────────────────────────────────────────
+describe("allTimeLowAlertWorker", () => {
+  function getAllTimeLowAlertProcessor(): (job: unknown) => Promise<void> {
+    const calls = vi.mocked(Worker).mock.calls;
+    const call = calls.find(([name]) => name === "all-time-low");
+    if (!call) throw new Error("All-time-low alert Worker was not created");
+    return call[1] as (job: unknown) => Promise<void>;
+  }
+
+  const mockListing = { id: "listing-1", storeId: "store-1", gameId: "game-1" };
+
+  function buildInsertChain(returning: unknown[] = []) {
+    return {
+      values: vi.fn().mockReturnThis(),
+      onConflictDoUpdate: vi.fn().mockReturnThis(),
+      returning: vi.fn().mockResolvedValue(returning),
+      set: vi.fn().mockReturnThis(),
+    };
+  }
+
+  it("should create a Worker for the 'all-time-low' queue", () => {
+    const calls = vi.mocked(Worker).mock.calls;
+    const call = calls.find(([name]) => name === "all-time-low");
+    expect(call).toBeDefined();
+  });
+
+  it("should trigger all active alerts unconditionally", async () => {
+    const alerts = [
+      { id: "alert-a", userId: "user-1", gameId: "game-1", storeId: null, notifyEmail: true, notifySlackWebhook: null },
+      { id: "alert-b", userId: "user-2", gameId: "game-1", storeId: null, notifyEmail: false, notifySlackWebhook: "https://hooks.slack.com/x" },
+    ];
+
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValueOnce(buildSelectChain(alerts))         // active alerts
+      .mockReturnValueOnce(buildSelectChain([mockListing]))  // listing for alert-a
+      .mockReturnValueOnce(buildSelectChain([mockListing])); // listing for alert-b
+
+    const insertChain = buildInsertChain([]);
+    (db.insert as ReturnType<typeof vi.fn>).mockReturnValue(insertChain);
+    mockQueueAdd.mockClear();
+
+    const processor = getAllTimeLowAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", newPrice: 4.99 } });
+
+    const notifCalls = mockQueueAdd.mock.calls.filter(([name]: [string]) => name === "alert-notification");
+    expect(notifCalls).toHaveLength(2);
+    expect(notifCalls[0][1]).toEqual(expect.objectContaining({ alertId: "alert-a", triggeredPrice: 4.99 }));
+    expect(notifCalls[1][1]).toEqual(expect.objectContaining({ alertId: "alert-b", triggeredPrice: 4.99 }));
+  });
+
+  it("should skip alerts scoped to a different store", async () => {
+    const alert = {
+      id: "alert-c", userId: "user-1", gameId: "game-1", storeId: "other-store-id",
+      notifyEmail: true, notifySlackWebhook: null,
+    };
+
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValueOnce(buildSelectChain([alert]))        // active alerts
+      .mockReturnValueOnce(buildSelectChain([mockListing])); // listing.storeId = "store-1" != "other-store-id"
+
+    mockQueueAdd.mockClear();
+
+    const processor = getAllTimeLowAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", newPrice: 4.99 } });
+
+    const notifCalls = mockQueueAdd.mock.calls.filter(([name]: [string]) => name === "alert-notification");
+    expect(notifCalls).toHaveLength(0);
+  });
+
+  it("should handle no active alerts gracefully", async () => {
+    // Clear once-queue and re-establish default so no stale mocks leak in
+    (db.select as ReturnType<typeof vi.fn>).mockReset();
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValue(buildSelectChain([]))  // default fallback
+      .mockReturnValueOnce(buildSelectChain([])); // active alerts → empty
+
+    mockQueueAdd.mockClear();
+
+    const processor = getAllTimeLowAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", newPrice: 4.99 } });
+
+    const notifCalls = mockQueueAdd.mock.calls.filter(([name]: [string]) => name === "alert-notification");
+    expect(notifCalls).toHaveLength(0);
+  });
+
+  it("should insert alertNotifications row with correct triggeredPrice", async () => {
+    const alert = {
+      id: "alert-d", userId: "user-1", gameId: "game-1", storeId: null,
+      notifyEmail: true, notifySlackWebhook: null,
+    };
+
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValueOnce(buildSelectChain([alert]))
+      .mockReturnValueOnce(buildSelectChain([mockListing]));
+
+    const insertValuesChain = { values: vi.fn().mockReturnThis(), returning: vi.fn().mockResolvedValue([{}]) };
+    (db.insert as ReturnType<typeof vi.fn>).mockReturnValue(insertValuesChain);
+
+    const processor = getAllTimeLowAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", newPrice: 3.99 } });
+
+    const valuesArg = insertValuesChain.values.mock.calls.find(
+      ([v]: [{ triggeredPrice?: string }]) => v.triggeredPrice !== undefined,
+    );
+    expect(valuesArg).toBeDefined();
+    expect(valuesArg![0].triggeredPrice).toBe("3.99");
+  });
+
+  it("should enqueue notification with correct userId and notification preferences", async () => {
+    const alert = {
+      id: "alert-e", userId: "user-42", gameId: "game-1", storeId: null,
+      notifyEmail: false, notifySlackWebhook: "https://hooks.slack.com/test",
+    };
+
+    (db.select as ReturnType<typeof vi.fn>)
+      .mockReturnValueOnce(buildSelectChain([alert]))
+      .mockReturnValueOnce(buildSelectChain([mockListing]));
+
+    const insertChain = buildInsertChain([]);
+    (db.insert as ReturnType<typeof vi.fn>).mockReturnValue(insertChain);
+    mockQueueAdd.mockClear();
+
+    const processor = getAllTimeLowAlertProcessor();
+    await processor({ data: { gameId: "game-1", storeListingId: "listing-1", newPrice: 2.99 } });
+
+    expect(mockQueueAdd).toHaveBeenCalledWith(
+      "alert-notification",
+      expect.objectContaining({
+        userId: "user-42",
+        notifyEmail: false,
+        notifySlackWebhook: "https://hooks.slack.com/test",
+      }),
+    );
+  });
+});
+
+// ─── Graceful shutdown tests ──────────────────────────────────────────────────
+describe("graceful shutdown", () => {
+  it("should include priceDropAlertWorker and allTimeLowAlertWorker in shutdown", () => {
+    const calls = vi.mocked(Worker).mock.calls;
+    const priceDropCall = calls.find(([name]) => name === "price-drop");
+    const allTimeLowCall = calls.find(([name]) => name === "all-time-low");
+    expect(priceDropCall).toBeDefined();
+    expect(allTimeLowCall).toBeDefined();
+    // Workers are created → they will be closed during SIGTERM (tested via afterAll)
+  });
+});
