diff --git a/packages/api/src/routes/alerts.ts b/packages/api/src/routes/alerts.ts
new file mode 100644
index 0000000..86fd0ea
--- /dev/null
+++ b/packages/api/src/routes/alerts.ts
@@ -0,0 +1,212 @@
+import { Hono } from "hono";
+import { eq, and, sql } from "drizzle-orm";
+import { db, priceAlerts, games } from "@taad/db";
+import { authMiddleware } from "../middleware/auth.js";
+import { createAlertSchema, updateAlertSchema } from "../lib/validation.js";
+import { encrypt, decrypt } from "../lib/encryption.js";
+
+const MAX_ACTIVE_ALERTS = 100;
+
+type Variables = { user: Record<string, unknown> };
+
+const app = new Hono<{ Variables: Variables }>();
+
+// All endpoints require authentication
+app.use("*", authMiddleware);
+
+// GET / — list all alerts for the authenticated user
+app.get("/", async (c) => {
+  const user = c.get("user");
+  const userId = user.sub as string;
+
+  const rows = await db
+    .select()
+    .from(priceAlerts)
+    .where(eq(priceAlerts.userId, userId));
+
+  const decrypted = rows.map((row) => ({
+    ...row,
+    notifySlackWebhook: row.notifySlackWebhook
+      ? decrypt(row.notifySlackWebhook)
+      : null,
+  }));
+
+  return c.json({ data: decrypted });
+});
+
+// POST / — create a new alert
+app.post("/", async (c) => {
+  const user = c.get("user");
+  const userId = user.sub as string;
+
+  const body = await c.req.json();
+  const parsed = createAlertSchema.safeParse(body);
+  if (!parsed.success) {
+    return c.json(
+      { error: "Invalid input", details: parsed.error.flatten() },
+      400,
+    );
+  }
+
+  const { gameId, storeId, targetPrice, targetDiscountPercent, notifyEmail, notifySlackWebhook } = parsed.data;
+
+  // Verify gameId exists
+  const [game] = await db
+    .select({ id: games.id })
+    .from(games)
+    .where(eq(games.id, gameId))
+    .limit(1);
+
+  if (!game) {
+    return c.json({ error: "Game not found" }, 400);
+  }
+
+  // Enforce 100 active alert cap
+  const [countResult] = await db
+    .select({ count: sql<number>`count(*)::int` })
+    .from(priceAlerts)
+    .where(and(eq(priceAlerts.userId, userId), eq(priceAlerts.isActive, true)));
+
+  if (countResult && countResult.count >= MAX_ACTIVE_ALERTS) {
+    return c.json({ error: "Active alert limit reached (100)" }, 409);
+  }
+
+  const [created] = await db
+    .insert(priceAlerts)
+    .values({
+      userId,
+      gameId,
+      storeId: storeId ?? null,
+      targetPrice: targetPrice?.toString() ?? null,
+      targetDiscountPercent: targetDiscountPercent?.toString() ?? null,
+      notifyEmail: notifyEmail ?? true,
+      notifySlackWebhook: notifySlackWebhook ? encrypt(notifySlackWebhook) : null,
+    })
+    .returning();
+
+  if (!created) {
+    return c.json({ error: "Failed to create alert" }, 400);
+  }
+
+  return c.json(
+    {
+      data: {
+        ...created,
+        notifySlackWebhook: notifySlackWebhook ?? null,
+      },
+    },
+    201,
+  );
+});
+
+// PATCH /:alertId — update an existing alert
+app.patch("/:alertId", async (c) => {
+  const user = c.get("user");
+  const userId = user.sub as string;
+  const alertId = c.req.param("alertId");
+
+  const body = await c.req.json();
+  const parsed = updateAlertSchema.safeParse(body);
+  if (!parsed.success) {
+    return c.json(
+      { error: "Invalid input", details: parsed.error.flatten() },
+      400,
+    );
+  }
+
+  // Check existence and ownership
+  const [existing] = await db
+    .select({ id: priceAlerts.id, userId: priceAlerts.userId })
+    .from(priceAlerts)
+    .where(eq(priceAlerts.id, alertId))
+    .limit(1);
+
+  if (!existing || existing.userId !== userId) {
+    return c.json({ error: "Alert not found" }, 404);
+  }
+
+  const updates: Record<string, unknown> = { updatedAt: new Date() };
+  const { storeId, targetPrice, targetDiscountPercent, notifyEmail, notifySlackWebhook } = parsed.data;
+
+  if (storeId !== undefined) updates.storeId = storeId;
+  if (targetPrice !== undefined) updates.targetPrice = targetPrice.toString();
+  if (targetDiscountPercent !== undefined) updates.targetDiscountPercent = targetDiscountPercent.toString();
+  if (notifyEmail !== undefined) updates.notifyEmail = notifyEmail;
+  if (notifySlackWebhook !== undefined) updates.notifySlackWebhook = encrypt(notifySlackWebhook);
+
+  const [updated] = await db
+    .update(priceAlerts)
+    .set(updates)
+    .where(eq(priceAlerts.id, alertId))
+    .returning();
+
+  return c.json({
+    data: {
+      ...updated,
+      notifySlackWebhook: updated?.notifySlackWebhook
+        ? decrypt(updated.notifySlackWebhook)
+        : null,
+    },
+  });
+});
+
+// DELETE /:alertId — delete an alert
+app.delete("/:alertId", async (c) => {
+  const user = c.get("user");
+  const userId = user.sub as string;
+  const alertId = c.req.param("alertId");
+
+  const [existing] = await db
+    .select({ id: priceAlerts.id, userId: priceAlerts.userId })
+    .from(priceAlerts)
+    .where(eq(priceAlerts.id, alertId))
+    .limit(1);
+
+  if (!existing || existing.userId !== userId) {
+    return c.json({ error: "Alert not found" }, 404);
+  }
+
+  await db.delete(priceAlerts).where(eq(priceAlerts.id, alertId));
+
+  return c.body(null, 204);
+});
+
+// PATCH /:alertId/pause — set isActive
+app.patch("/:alertId/pause", async (c) => {
+  const user = c.get("user");
+  const userId = user.sub as string;
+  const alertId = c.req.param("alertId");
+
+  const body = await c.req.json();
+  const { isActive } = body;
+  if (typeof isActive !== "boolean") {
+    return c.json({ error: "isActive must be a boolean" }, 400);
+  }
+
+  const [existing] = await db
+    .select({ id: priceAlerts.id, userId: priceAlerts.userId })
+    .from(priceAlerts)
+    .where(eq(priceAlerts.id, alertId))
+    .limit(1);
+
+  if (!existing || existing.userId !== userId) {
+    return c.json({ error: "Alert not found" }, 404);
+  }
+
+  const [updated] = await db
+    .update(priceAlerts)
+    .set({ isActive, updatedAt: new Date() })
+    .where(eq(priceAlerts.id, alertId))
+    .returning();
+
+  return c.json({
+    data: {
+      ...updated,
+      notifySlackWebhook: updated?.notifySlackWebhook
+        ? decrypt(updated.notifySlackWebhook)
+        : null,
+    },
+  });
+});
+
+export { app as alertsApp };
