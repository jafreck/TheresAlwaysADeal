+++ b/packages/api/tests/routes/alerts.test.ts
@@ -0,0 +1,766 @@
+import { describe, it, expect, vi, beforeEach } from "vitest";
+
+// ─── Mocks (hoisted before imports) ──────────────────────────────────────────
+
+const mockEncrypt = vi.fn((v: string) => `encrypted:${v}`);
+const mockDecrypt = vi.fn((v: string) => v.replace("encrypted:", ""));
+
+vi.mock("../../src/lib/encryption.js", () => ({
+  encrypt: (...args: unknown[]) => mockEncrypt(...args),
+  decrypt: (...args: unknown[]) => mockDecrypt(...args),
+}));
+
+const mockVerifyAccessToken = vi.fn();
+vi.mock("../../src/lib/jwt.js", () => ({
+  verifyAccessToken: (...args: unknown[]) => mockVerifyAccessToken(...args),
+}));
+
+// DB mock
+let mockDbSelectResult: any[] = [];
+let mockDbInsertResult: any[] = [];
+let mockDbUpdateResult: any[] = [];
+let mockDbDeleteCalled = false;
+
+function createSelectBuilder() {
+  const builder: any = {
+    from: () => builder,
+    where: () => builder,
+    limit: () => Promise.resolve(mockDbSelectResult),
+    then: (resolve: (v: any) => any, reject: (e: any) => any) =>
+      Promise.resolve(mockDbSelectResult).then(resolve, reject),
+  };
+  return builder;
+}
+
+function createInsertBuilder() {
+  return {
+    values: vi.fn().mockReturnValue({
+      returning: vi.fn().mockImplementation(() => Promise.resolve(mockDbInsertResult)),
+    }),
+  };
+}
+
+function createUpdateBuilder() {
+  return {
+    set: vi.fn().mockReturnValue({
+      where: vi.fn().mockReturnValue({
+        returning: vi.fn().mockImplementation(() => Promise.resolve(mockDbUpdateResult)),
+      }),
+    }),
+  };
+}
+
+function createDeleteBuilder() {
+  return {
+    where: vi.fn().mockImplementation(() => {
+      mockDbDeleteCalled = true;
+      return Promise.resolve();
+    }),
+  };
+}
+
+const mockDb = {
+  select: vi.fn().mockReturnValue(createSelectBuilder()),
+  insert: vi.fn().mockReturnValue(createInsertBuilder()),
+  update: vi.fn().mockReturnValue(createUpdateBuilder()),
+  delete: vi.fn().mockReturnValue(createDeleteBuilder()),
+};
+
+const stubTable = (cols: Record<string, string>) => cols;
+
+vi.mock("@taad/db", () => ({
+  db: mockDb,
+  priceAlerts: stubTable({
+    id: "id",
+    userId: "userId",
+    gameId: "gameId",
+    storeId: "storeId",
+    targetPrice: "targetPrice",
+    targetDiscountPercent: "targetDiscountPercent",
+    notifyEmail: "notifyEmail",
+    notifySlackWebhook: "notifySlackWebhook",
+    isActive: "isActive",
+    createdAt: "createdAt",
+    updatedAt: "updatedAt",
+  }),
+  games: stubTable({
+    id: "id",
+    title: "title",
+    slug: "slug",
+  }),
+}));
+
+vi.mock("drizzle-orm", () => ({
+  eq: vi.fn((col: string, val: unknown) => ({ col, val })),
+  and: vi.fn((...args: unknown[]) => args),
+  sql: Object.assign(vi.fn(), {
+    raw: vi.fn((s: string) => s),
+  }),
+}));
+
+// ─── App under test ───────────────────────────────────────────────────────────
+
+const { alertsApp } = await import("../../src/routes/alerts.js");
+
+// ─── Helpers ──────────────────────────────────────────────────────────────────
+
+const TEST_USER_ID = "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee";
+const TEST_ALERT_ID = "11111111-2222-3333-4444-555555555555";
+const TEST_GAME_ID = "99999999-8888-7777-6666-555555555555";
+
+function authHeaders(): Record<string, string> {
+  return { Authorization: "Bearer valid-token" };
+}
+
+function jsonHeaders(): Record<string, string> {
+  return {
+    ...authHeaders(),
+    "Content-Type": "application/json",
+  };
+}
+
+// ─── Tests ────────────────────────────────────────────────────────────────────
+
+beforeEach(() => {
+  vi.clearAllMocks();
+  mockDbSelectResult = [];
+  mockDbInsertResult = [];
+  mockDbUpdateResult = [];
+  mockDbDeleteCalled = false;
+  mockVerifyAccessToken.mockReturnValue({ sub: TEST_USER_ID, email: "test@example.com" });
+  mockDb.select.mockReturnValue(createSelectBuilder());
+  mockDb.insert.mockReturnValue(createInsertBuilder());
+  mockDb.update.mockReturnValue(createUpdateBuilder());
+  mockDb.delete.mockReturnValue(createDeleteBuilder());
+});
+
+describe("alertsApp auth", () => {
+  it("should return 401 when no Authorization header is provided", async () => {
+    const res = await alertsApp.request("/");
+    expect(res.status).toBe(401);
+  });
+
+  it("should return 401 when Authorization header has invalid format", async () => {
+    const res = await alertsApp.request("/", {
+      headers: { Authorization: "InvalidFormat" },
+    });
+    expect(res.status).toBe(401);
+  });
+
+  it("should return 401 when token is invalid", async () => {
+    mockVerifyAccessToken.mockImplementation(() => {
+      throw new Error("Invalid token");
+    });
+    const res = await alertsApp.request("/", {
+      headers: authHeaders(),
+    });
+    expect(res.status).toBe(401);
+  });
+});
+
+describe("GET / (list alerts)", () => {
+  it("should return 200 with empty array when user has no alerts", async () => {
+    mockDbSelectResult = [];
+    const res = await alertsApp.request("/", { headers: authHeaders() });
+    expect(res.status).toBe(200);
