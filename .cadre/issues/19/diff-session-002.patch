+// ─── Price-Drop Alert Worker ──────────────────────────────────────────────────
+const priceDropAlertWorker = new Worker(
+  "price-drop",
+  async (job) => {
+    const { gameId, storeListingId, newPrice } = job.data as {
+      gameId: string;
+      storeListingId: string;
+      previousPrice: number;
+      newPrice: number;
+    };
+
+    // Look up the store listing to get storeId for store-scoped alert filtering
+    const [listing] = await db
+      .select()
+      .from(storeListings)
+      .where(eq(storeListings.id, storeListingId))
+      .limit(1);
+    if (!listing) return;
+
+    // Query active alerts for this game
+    const activeAlerts = await db
+      .select()
+      .from(priceAlerts)
+      .where(and(eq(priceAlerts.gameId, gameId), eq(priceAlerts.isActive, true)));
+
+    for (const alert of activeAlerts) {
+      // Skip if alert is scoped to a different store
+      if (alert.storeId && alert.storeId !== listing.storeId) continue;
+
+      const meetsPrice = alert.targetPrice != null && newPrice <= Number(alert.targetPrice);
+      // Compute discount from the latest price history record
+      const [latestRecord] = await db
+        .select()
+        .from(priceHistory)
+        .where(eq(priceHistory.storeListingId, storeListingId))
+        .orderBy(desc(priceHistory.recordedAt))
+        .limit(1);
+      const discountPercent = latestRecord?.discount != null ? Number(latestRecord.discount) : 0;
+      const meetsDiscount = alert.targetDiscountPercent != null && discountPercent >= Number(alert.targetDiscountPercent);
+
+      if (!meetsPrice && !meetsDiscount) continue;
+
+      // Enqueue notification job
+      await notificationQueue.add("alert-notification", {
+        alertId: alert.id,
+        userId: alert.userId,
+        gameId,
+        storeListingId,
+        triggeredPrice: newPrice,
+        notifyEmail: alert.notifyEmail,
+        notifySlackWebhook: alert.notifySlackWebhook,
+      });
+
+      // Record notification
+      await db.insert(alertNotifications).values({
+        alertId: alert.id,
+        storeListingId,
+        triggeredPrice: String(newPrice),
+      });
+    }
+  },
+  { connection },
+);
+
+// ─── All-Time-Low Alert Worker ────────────────────────────────────────────────
+const allTimeLowAlertWorker = new Worker(
+  "all-time-low",
+  async (job) => {
