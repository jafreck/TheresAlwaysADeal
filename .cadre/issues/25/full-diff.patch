+    mockGet.mockResolvedValue({});
+    render(<VerifyEmailPage />);
+
+    await waitFor(() => {
+      expect(mockGet).toHaveBeenCalledWith(
+        `/api/auth/verify-email?token=${encodeURIComponent('token with spaces&special=chars')}`,
+      );
+    });
+  });
+});
