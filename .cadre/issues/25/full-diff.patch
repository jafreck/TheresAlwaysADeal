+            )
+            .limit(1);
+
+          if (!existing) {
+            await db
+              .insert(wishlists)
+              .values({ userId: user.id, gameId: game.id, source: "steam_sync" });
+          }
+        }
+      } catch (err) {
+        console.warn(
+          JSON.stringify({ event: "steam-sync-error", userId: user.id, error: String(err) }),
+        );
+      }
+    }
+  },
+  { connection, concurrency: 1 },
+);
