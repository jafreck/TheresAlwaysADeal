+    expect(html).toContain(`href="${samplePrices[0].referralUrl}"`);
+    expect(html).toContain(`href="${samplePrices[1].referralUrl}"`);
+    expect(html).toContain("Buy");
+  });
+
+  it("should include the unsubscribe link", () => {
