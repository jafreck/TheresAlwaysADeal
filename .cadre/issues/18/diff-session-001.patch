diff --git a/packages/api/src/routes/wishlist.ts b/packages/api/src/routes/wishlist.ts
new file mode 100644
index 0000000..58c24a7
--- /dev/null
+++ b/packages/api/src/routes/wishlist.ts
@@ -0,0 +1,212 @@
+import { Hono } from "hono";
+import { eq, sql, and, count, desc } from "drizzle-orm";
+import {
+  db,
+  wishlists,
+  games,
+  storeListings,
+  stores,
+  priceHistory,
+  priceAlerts,
+} from "@taad/db";
+import { addToWishlistSchema, wishlistPaginationSchema } from "../lib/validation.js";
+import { buildEnvelopeResponse } from "../lib/response.js";
+
+type Env = {
+  Variables: {
+    user: Record<string, unknown>;
+  };
+};
+
+export function createWishlistApp() {
+  const app = new Hono<Env>();
+
+  // GET / — paginated wishlist with best prices per game
+  app.get("/", async (c) => {
+    const user = c.get("user") as { sub: string };
+    const parsed = wishlistPaginationSchema.safeParse(c.req.query());
+    if (!parsed.success) {
+      return c.json({ error: "Invalid query parameters", details: parsed.error.flatten() }, 400);
+    }
+    const { page, limit } = parsed.data;
+    const offset = (page - 1) * limit;
+
+    const userCondition = eq(wishlists.userId, user.sub);
+
+    const [totalResult] = await db
+      .select({ total: count() })
+      .from(wishlists)
+      .where(userCondition);
+    const total = totalResult?.total ?? 0;
+
+    const rows = await db
+      .select({
+        wishlistId: wishlists.id,
+        gameId: games.id,
+        gameTitle: games.title,
+        gameSlug: games.slug,
+        headerImageUrl: games.headerImageUrl,
+        source: wishlists.source,
+        addedAt: wishlists.createdAt,
+        storeName: stores.name,
+        storeLogoUrl: stores.logoUrl,
+        currentPriceCents: priceHistory.price,
+        originalPriceCents: priceHistory.originalPrice,
+        discountPercent: priceHistory.discount,
+        buyUrl: storeListings.storeUrl,
+      })
+      .from(wishlists)
+      .innerJoin(games, eq(games.id, wishlists.gameId))
+      .leftJoin(
+        storeListings,
+        sql`${storeListings.gameId} = ${games.id}
+            AND ${storeListings.isActive} = true
+            AND ${storeListings.id} = (
+              SELECT sl2.id FROM store_listings sl2
+              INNER JOIN price_history ph2 ON ph2.store_listing_id = sl2.id
+              WHERE sl2.game_id = ${games.id} AND sl2.is_active = true
+              ORDER BY ph2.price ASC, ph2.recorded_at DESC
+              LIMIT 1
+            )`,
+      )
+      .leftJoin(stores, eq(stores.id, storeListings.storeId))
+      .leftJoin(
+        priceHistory,
+        sql`${priceHistory.storeListingId} = ${storeListings.id}
+            AND ${priceHistory.recordedAt} = (
+              SELECT MAX(ph3.recorded_at) FROM price_history ph3
+              WHERE ph3.store_listing_id = ${storeListings.id}
+            )`,
+      )
+      .where(userCondition)
+      .orderBy(desc(wishlists.createdAt))
+      .limit(limit)
+      .offset(offset);
+
+    return c.json(buildEnvelopeResponse(rows, total, page, limit));
+  });
+
+  // POST / — add a game to the wishlist
+  app.post("/", async (c) => {
+    const user = c.get("user") as { sub: string };
+    const body = await c.req.json();
+    const parsed = addToWishlistSchema.safeParse(body);
+    if (!parsed.success) {
+      return c.json({ error: "Invalid request body", details: parsed.error.flatten() }, 400);
+    }
+    const { gameId } = parsed.data;
+
+    const [entry] = await db
+      .insert(wishlists)
+      .values({ userId: user.sub, gameId, source: "manual" })
+      .returning();
+
+    // Check whether an active price alert exists for this user+game
+    const [alert] = await db
+      .select({ id: priceAlerts.id })
+      .from(priceAlerts)
+      .where(
+        and(
+          eq(priceAlerts.userId, user.sub),
+          eq(priceAlerts.gameId, gameId),
+          eq(priceAlerts.isActive, true),
+        ),
+      )
+      .limit(1);
+
+    return c.json({ entry, hasPriceAlert: !!alert }, 201);
+  });
+
+  // DELETE /:gameId — remove a game from the wishlist
+  app.delete("/:gameId", async (c) => {
+    const user = c.get("user") as { sub: string };
+    const { gameId } = c.req.param();
+
+    const deleted = await db
+      .delete(wishlists)
+      .where(and(eq(wishlists.userId, user.sub), eq(wishlists.gameId, gameId)))
+      .returning();
+
+    if (deleted.length === 0) {
+      return c.json({ error: "Wishlist entry not found" }, 404);
+    }
+
+    return c.body(null, 204);
+  });
+
+  // GET /deals — wishlist items currently on sale
+  app.get("/deals", async (c) => {
+    const user = c.get("user") as { sub: string };
+    const parsed = wishlistPaginationSchema.safeParse(c.req.query());
+    if (!parsed.success) {
+      return c.json({ error: "Invalid query parameters", details: parsed.error.flatten() }, 400);
+    }
+    const { page, limit } = parsed.data;
+    const offset = (page - 1) * limit;
+
+    const onSaleCondition = and(
+      eq(wishlists.userId, user.sub),
+      sql`${priceHistory.discount} IS NOT NULL AND ${priceHistory.discount} > 0`,
+    );
+
+    const [totalResult] = await db
+      .select({ total: count() })
+      .from(wishlists)
+      .innerJoin(games, eq(games.id, wishlists.gameId))
+      .innerJoin(
+        storeListings,
+        sql`${storeListings.gameId} = ${games.id} AND ${storeListings.isActive} = true`,
+      )
+      .innerJoin(
+        priceHistory,
+        sql`${priceHistory.storeListingId} = ${storeListings.id}
+            AND ${priceHistory.recordedAt} = (
+              SELECT MAX(ph2.recorded_at) FROM price_history ph2
+              WHERE ph2.store_listing_id = ${storeListings.id}
+            )`,
+      )
+      .innerJoin(stores, eq(stores.id, storeListings.storeId))
+      .where(onSaleCondition);
+    const total = totalResult?.total ?? 0;
+
+    const rows = await db
+      .select({
+        wishlistId: wishlists.id,
+        gameId: games.id,
+        gameTitle: games.title,
+        gameSlug: games.slug,
+        headerImageUrl: games.headerImageUrl,
+        source: wishlists.source,
+        addedAt: wishlists.createdAt,
+        storeName: stores.name,
+        storeLogoUrl: stores.logoUrl,
+        currentPriceCents: priceHistory.price,
+        originalPriceCents: priceHistory.originalPrice,
+        discountPercent: priceHistory.discount,
+        buyUrl: storeListings.storeUrl,
+      })
+      .from(wishlists)
+      .innerJoin(games, eq(games.id, wishlists.gameId))
+      .innerJoin(
+        storeListings,
+        sql`${storeListings.gameId} = ${games.id} AND ${storeListings.isActive} = true`,
+      )
+      .innerJoin(
+        priceHistory,
+        sql`${priceHistory.storeListingId} = ${storeListings.id}
+            AND ${priceHistory.recordedAt} = (
+              SELECT MAX(ph2.recorded_at) FROM price_history ph2
+              WHERE ph2.store_listing_id = ${storeListings.id}
+            )`,
+      )
+      .innerJoin(stores, eq(stores.id, storeListings.storeId))
+      .where(onSaleCondition)
+      .orderBy(desc(priceHistory.discount))
+      .limit(limit)
+      .offset(offset);
+
+    return c.json(buildEnvelopeResponse(rows, total, page, limit));
+  });
+
+  return app;
+}
